{
    "name": "skill-creator",
    "version": "1.0.0",
    "description": "Generate production-ready Claude Skills for any project stack",
    "author": "Marcelo <your@email.com>",
    "license": "MIT",
    "keywords": [
        "claude",
        "anthropic",
        "skill",
        "ai",
        "cli",
        "code-generator",
        "developer-tools",
        "llm"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/YOUR_USER/skill-creator.git"
    },
    "homepage": "https://skill-creator.vercel.app",
    "bin": {
        "skill-creator": "./bin/skill-creator.js"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
        "clean": "rm -rf .next out dist",
        "release": "npm run typecheck && npm run build && npm publish --access public"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.37.0",
        "jszip": "^3.10.1",
        "next": "^14.2.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0"
    },
    "devDependencies": {
        "@types/jszip": "^3.4.0",
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "eslint": "^8",
        "eslint-config-next": "^14.2.0",
        "prettier": "^3.3.0",
        "typescript": "^5"
    },
    "optionalDependencies": {
        "@upstash/ratelimit": "^1.2.0",
        "@upstash/redis": "^1.34.0"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=9.0.0"
    }
}
