# ─── Anthropic ────────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública (usado em OG tags e links de compartilhamento)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Opcional — Rate limiting (Upstash Redis) ─────────────────────────────────
# Evita abuso da API em produção. Crie em: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ─── Opcional — Analytics ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com